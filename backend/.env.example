# Environment variables template
# Copy this file to .env and fill in the values

# Application Settings
APP_NAME=reproductive-health-risk-prediction
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Model Configuration
MODEL_PATH=../ml
MODEL_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database (PostgreSQL)
# Preferred in production/deployed environments:
# DATABASE_URL=postgresql://postgres:Anna%40psql@db-host:5432/reproductive_health?sslmode=require

# Local development fallback if DATABASE_URL is not set:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=reproductive_health
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Anna@psql
POSTGRES_SSLMODE=prefer

# API Keys (if needed)
# API_KEY=
